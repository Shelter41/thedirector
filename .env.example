# ── Storage ──────────────────────────────────────────────────────────
# Where raw messages, wiki, chat history, and credentials live.
# Use an absolute path in production so cwd doesn't matter.
DATA_ROOT=./data

# Optional Fernet key for encrypting data/credentials.json at rest.
# Leave empty for plain JSON (still secure: file is mode 0600 — same
# threat model as ~/.ssh/id_rsa).
# Generate one with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
MASTER_KEY=

# ── URLs ─────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google OAuth (Gmail) ─────────────────────────────────────────────
# Get these at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: http://localhost:8000/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack OAuth (optional) ───────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Models (optional overrides) ──────────────────────────────────────
# TRIAGE_MODEL=claude-haiku-4-5-20251001
# WRITER_MODEL=claude-haiku-4-5-20251001
# INDEX_MODEL=claude-haiku-4-5-20251001
# QUERY_MODEL=claude-sonnet-4-6
# BATCH_SIZE=15
