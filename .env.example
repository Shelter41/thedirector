# ── Storage ──────────────────────────────────────────────────────────
# Where raw messages, wiki, and chat history live. Use an absolute path
# in production so cwd doesn't matter.
DATA_ROOT=./data

# ── URLs ─────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Postgres ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://thedirector:thedirector_dev@localhost:5433/thedirector

# ── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google OAuth (Gmail) ─────────────────────────────────────────────
# Get these at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: http://localhost:8000/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack OAuth (optional) ───────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Models (optional overrides) ──────────────────────────────────────
# TRIAGE_MODEL=claude-haiku-4-5-20251001
# WRITER_MODEL=claude-haiku-4-5-20251001
# INDEX_MODEL=claude-haiku-4-5-20251001
# QUERY_MODEL=claude-sonnet-4-6
# BATCH_SIZE=15
